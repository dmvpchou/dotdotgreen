---
import '../styles/site.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getBrands, CATEGORY_META } from '../data/brands';
import { STATIONS } from '../data/stations';
import { MARKETS } from '../data/markets';

const { title, description = "", current = "", extraScripts = [] } = Astro.props;

const brands = await getBrands();
const WEEKDAY_INDEX = { "日": 0, "一": 1, "二": 2, "三": 3, "四": 4, "五": 5, "六": 6 };
const WEEKDAY_LABELS = ["日", "一", "二", "三", "四", "五", "六"];

const ddgData = {
  BRANDS: brands,
  MARKETS,
  STATIONS,
  CATEGORY_META,
  WEEKDAY_INDEX,
  WEEKDAY_LABELS,
};
---
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  {description && <meta name="description" content={description}>}
</head>
<body>

<Header current={current} />

<main>
  <slot />
</main>

<Footer />

<div class="sheet-overlay"><div class="sheet-panel"></div></div>
<canvas id="dot-trail" aria-hidden="true" style="position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:95"></canvas>

<script is:inline define:vars={{ ddgData }}>
  window.DDG_DATA = ddgData;
</script>
<script is:inline src="/scripts/data-bridge.js"></script>
<script is:inline src="/scripts/mouse-trail.js"></script>
<script is:inline src="/scripts/site.js"></script>
{extraScripts.map((src) => <script is:inline src={src}></script>)}
</body>
</html>
