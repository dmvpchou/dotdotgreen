---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MarketCard from '../components/MarketCard.astro';
import { MARKETS } from '../data/markets';
---
<BaseLayout title="本週出攤 · 點點綠官網" description="查看點點綠市集的現行時段，並前往官方粉專確認本週品牌與臨時異動。">

  <section style="position:relative;overflow:hidden;padding:56px 0 8px">
    <span class="scatter" style="top:24px;right:90px;width:96px;height:96px;background:color-mix(in srgb, var(--honey) 20%, transparent)"></span>
    <div class="wrap" style="position:relative">
      <SectionHeader eyebrow="出攤資訊" title="本週出攤" dotCategory="weekday" />
      <p style="margin:14px 0 0;font-size:var(--fs-lg);font-weight:300;max-width:640px;line-height:1.8">
        每週品牌會隨產季、站點與臨時狀況調整。本站目前沒有主辦方提供的日期班表，因此不再用設計示範資料推算每日名單。
      </p>
    </div>
  </section>

  <section class="wrap" style="padding:36px 24px 8px">
    <div class="market-grid">
      {MARKETS.map((m) => <MarketCard market={m} order="when-first" boxedNote />)}
    </div>
  </section>

  <section class="wrap" style="padding:20px 24px 64px">
    <div class="notice-band">最新品牌、站點與臨時異動，請以點點綠 Facebook 粉專當週公告為準。</div>
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:28px">
      <a class="btn btn-primary btn-dot" href="https://www.facebook.com/dotgreenmarket/" target="_blank" rel="noopener noreferrer">查看本週官方公告</a>
      <a class="btn btn-secondary" href="https://ddg.gdg.asia/" target="_blank" rel="noopener noreferrer">協會官網</a>
    </div>
    <p class="footnote-dot" style="margin-top:20px">待取得可公開使用的班表資料後，可再恢復週曆與月曆，並改用「日期＋站點＋品牌」資料模型。</p>
  </section>

</BaseLayout>
